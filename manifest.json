{
    "name": "AI USACO Tutor",
    "manifest_version": 3,
    "version": "1.0.0",
    "description": "An AI tutor that allows you to ask questions during an USACO problem",
    "permissions": ["storage", "tabs"],
    "host_permissions": [
    "https://usaco.org/*",
    "https://generativelanguage.googleapis.com/*"
    ],
    "content_scripts": [
        {
            "matches": ["https://usaco.org/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }   
    ],
    "background": {
    "service_worker": "background.js"
    },
    "action": {
    "default_title": "AI USACO Tutor",
    "default_icon": {
        "16": "test.png",
        "32": "test.png",
        "48": "test.png",
        "128": "test.png"
    }
    },
    "icons": {
    "16": "test.png",
    "32": "test.png",
    "48": "test.png",
    "128": "test.png"
    },
    "web_accessible_resources": [
    {
        "resources": ["test.png", "ratings.json"],
        "matches": ["https://usaco.org/*"]
    }
    ]
}
